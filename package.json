{
  "name": "dedic.eu",
  "version": "0.1.0",
  "description": "My personal website",
  "homepage": "https://dedic.eu",
  "bugs": {
    "url": "https://github.com/marekdedic/dedic.eu/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marekdedic/dedic.eu.git"
  },
  "license": "MIT",
  "author": "Marek Dědič",
  "type": "module",
  "exports": {
    ".": null
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "vite build",
    "clean": "rimraf dist/*",
    "lint": "run-p -c --aggregate-output lint:*",
    "lint:eslint": "eslint --color",
    "lint:svelte": "run-p -c --aggregate-output lint:svelte:*",
    "lint:svelte:svelte-check": "FORCE_COLOR=1 svelte-check",
    "lint:ts": "run-p -c --aggregate-output lint:ts:*",
    "lint:ts:typecheck": "tsc  --noEmit",
    "playwright-accept": "DOCKER_CMD='npx playwright test --update-snapshots' npm run playwright-docker-run",
    "playwright-docker-run": "docker run --name=\"npm-playwright\" --rm -p 8080:8080 --user=$(id -u):$(id -g) -v \"${PWD}:/var/app/\" --workdir=\"/var/app\" \"mcr.microsoft.com/playwright:v$(npm run --silent playwright-version)\" sh -c \"$DOCKER_CMD\"",
    "playwright-interactive": "sh -c 'trap \"echo ''Stopping container...'' && docker stop npm-playwright\" INT TERM; export DOCKER_CMD=\"exec npx playwright test --ui --ui-host=0.0.0.0 --ui-port=8080\"; npm run playwright-docker-run & SERVER_PID=$!; echo ''Waiting for Playwright UI on 8080...''; while ! curl -s --fail http://localhost:8080/ > /dev/null; do sleep 0.5; done; open \"http://localhost:8080\"; echo ''Playwright UI is running. Press Ctrl-C to stop the server.''; wait $SERVER_PID'",
    "playwright-version": "node -e 'console.log(require(\"./package-lock.json\")[\"packages\"][\"node_modules/@playwright/test\"].version)'",
    "prepare": "svelte-kit sync",
    "start": "vite",
    "test": "DOCKER_CMD='npm run test-native' npm run playwright-docker-run",
    "test-native": "playwright test"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@fontsource/roboto": "^5.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "^2.70.1",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@types/node": "^26.1.1",
    "@types/prismjs": "^1.26.6",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-package-json": "^1.6.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-playwright": "^2.10.5",
    "eslint-plugin-prefer-arrow-functions": "^3.10",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^14.0.0",
    "eslint-plugin-svelte": "^3.22.0",
    "globals": "^17.7.0",
    "katex": "^0.18.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "prismjs-bibtex": "^2.1.0",
    "rimraf": "^6.1.3",
    "rollup-plugin-htaccess": "^0.13.2",
    "sass": "^1.101.0",
    "svelte": "^5.56.7",
    "svelte-check": "^4.7.3",
    "svelte-fa": "^4.0.4",
    "svelte-sitemap": "^4.0.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-prismjs": "^0.0.11"
  }
}
